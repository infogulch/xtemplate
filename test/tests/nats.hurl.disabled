# DISABLED: this file is intentionally NOT run (the `.disabled` extension keeps
# `mise run test-cli` from picking it up).
#
# The assertion below targets the SSE endpoint GET /nats/messages, which is an
# indefinite Server-Sent Events stream. hurl blocks until the response body is
# fully written, but an SSE stream never terminates on its own, so any hurl
# assertion against it hangs forever. This is a fundamental hurl/SSE mismatch
# with no upstream fix, so the SSE stream cannot be exercised from hurl and this
# assertion must stay disabled. The terminating NATS endpoints are covered by
# the enabled nats.hurl.

GET http://localhost:8080/nats/messages
Accept: text/event-stream
HTTP 200
[Asserts]
duration < 1000
body contains "data: \"<li>hello 1</li>\"\n\n"
