{
  "apps": {
    "http": {
      "servers": {
        "": {
          "listen": [":8082"],
          "routes": [
            {
              "handle": [
                {
                  "handler": "xtemplate",
                  "minify": true,
                  "source": {"type": "os", "path": "templates"},
                  "providers": [
                    {
                      "type": "sql",
                      "name": "DB",
                      "driver": "sqlite3",
                      "connstr": "file:./test.sqlite"
                    },
                    {
                      "type": "fs",
                      "name": "FS",
                      "path": "data"
                    },
                    {
                      "type": "fs",
                      "name": "FSW",
                      "path": "."
                    },
                    {
                      "type": "flags",
                      "name": "Flags",
                      "values": {
                        "a": "1",
                        "b": "2",
                        "hello": "world"
                      }
                    },
                    {
                      "type": "nats",
                      "name": "Nats",
                      "nats_config": {
                        "in_process_server_options": {
                          "dont_listen": true
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    }
  },
  "logging": {
    "logs": {
      "": {
        "level": "DEBUG"
      }
    }
  }
}
