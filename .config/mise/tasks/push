#!/usr/bin/env nu
#MISE description="Push each unpushed commit individually so CI runs on every commit"
use ../lib.nu *
cd $env.ROOT

let upstream = (^git rev-parse --abbrev-ref --symbolic-full-name '@{u}' | str trim)
let remote = ($upstream | split row "/" | first)
let branch = ($upstream | split row "/" | skip 1 | str join "/")

if (do { ^git merge-base --is-ancestor $upstream HEAD } | complete | get exit_code) != 0 {
    print -e $"error: ($upstream) is not an ancestor of HEAD"
    exit 1
}

let commits = (^git rev-list --reverse $"($upstream)..HEAD" | lines)

for sha in $commits {
    ^git push $remote $"($sha):refs/heads/($branch)"
}
