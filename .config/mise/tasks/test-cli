#!/usr/bin/env nu
#MISE description="Build, serve, and integration-test the CLI binary"
#MISE depends=["build-cli"]
use ../lib.nu *

let work = (new-run-dir test-cli)
let bin = ($env.DIST_DIR | path join xtemplate)

# Start the server in a background job from the working dir so its relative
# config paths resolve; its combined output goes to the run's log. `job kill`
# tears it down whether the suite passes or fails.
let server = (job spawn {
    cd $work
    ^$bin --loglevel -4 --config-file config.json out+err> xtemplate.log
})

let outcome = (try { run-hurl 8080 ($work | path join report); "ok" } catch { |e| $e.msg })
job kill $server

if $outcome != "ok" {
    print -e $"test-cli failed: ($outcome)"
    exit 1
}
