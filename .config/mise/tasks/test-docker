#!/usr/bin/env bash
#MISE description="Build and integration-test the Docker image"
set -euo pipefail
# shellcheck source=/dev/null
source "$MISE_PROJECT_ROOT/.config/mise/lib.sh"
cd "$ROOT"

work="$(new_run_dir test-docker)"
copy_fixtures "$work"

docker build -t xtemplate-test --target test \
	--build-arg "LDFLAGS=$(xt_ldflags)" .

docker rm -f xtemplate-test 2>/dev/null || true
docker run -d --name xtemplate-test -p 8081:80 -v "$work:/app/dataw" xtemplate-test
trap 'docker logs xtemplate-test &>"$work/docker.log" || true; docker rm -f xtemplate-test 2>/dev/null || true' EXIT

wait_ready 8081
run_hurl 8081 "$work/report"
