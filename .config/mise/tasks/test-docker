#!/usr/bin/env nu
#MISE description="Build and integration-test the Docker image"
use ../lib.nu *

let work = (new-run-dir test-docker)

xt-build-docker --target test --tags [xtemplate-test]

do { ^docker rm -f xtemplate-test } | complete | ignore
^docker run -d --name xtemplate-test -p 8081:80 -v $"($work):/app/dataw" xtemplate-test

# Run the suite, then always capture the container log and remove it, whether
# the suite passed or failed.
let outcome = (try { run-hurl 8081 ($work | path join report); "ok" } catch { |e| $e.msg })
do { ^docker logs xtemplate-test } out+err> ($work | path join docker.log)
do { ^docker rm -f xtemplate-test } | complete | ignore

if $outcome != "ok" {
    print -e $"test-docker failed: ($outcome)"
    exit 1
}
