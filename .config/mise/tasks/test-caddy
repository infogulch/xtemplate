#!/usr/bin/env nu
#MISE description="Build and integration-test the Caddy module"
#MISE depends=["build-caddy"]
use ../lib.nu *

let work = (new-run-dir test-caddy)
let caddy = ($env.DIST_DIR | path join caddy)

# `caddy start` daemonizes, so it keeps running after this returns; stop it
# again once the suite finishes, whether it passes or fails.
do { cd $work; ^$caddy start --config caddy.json } out+err> ($work | path join caddy.log)

let outcome = (try { run-hurl 8082 ($work | path join report); "ok" } catch { |e| $e.msg })
do { ^$caddy stop } | complete | ignore

if $outcome != "ok" {
    print -e $"test-caddy failed: ($outcome)"
    exit 1
}
