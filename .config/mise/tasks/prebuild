#!/usr/bin/env nu
#MISE description="Download Go modules, pre-compile dependencies, and export the Docker deps build cache"
use ../lib.nu *
cd $env.ROOT

# Compute a stable hash of the dependency inputs (includes go version) up front.
let sum = (xt-prebuild-hash)

# All progress goes to stderr so stdout carries only the final hash.

# Download module sources into the cache. -json lets us print a one-line summary
# and surface per-module failures, which it reports in-band instead of failing.
# go emits a stream of concatenated, pretty-printed JSON objects, so stitch them
# into a single array (objects are flat and delimited by `}\n{` at column 0)
# before handing the whole thing to `from json`.
let raw = (^go mod download -json | str trim)
let joined = ($raw | str replace --all "}\n{" "},{")
let dl = ($"[($joined)]" | from json)
let errs = ($dl | where { |m| ($m.Error? | is-not-empty) } | each { |m| $"  failed: ($m.Path)@($m.Version): ($m.Error)" })
if not ($errs | is-empty) {
    print -e ($errs | str join "\n")
    exit 1
}
let bytes = ($dl | get Zip? | compact | each { |z| (ls $z | get 0.size) } | math sum)
print -e $"  downloaded ($dl | length) modules \(($bytes | into filesize))"

# Pre-compile only external dependency packages for every release platform to
# warm the Go build cache.  Excludes this module's own packages (.Module.Main)
# so the cache isn't polluted with a potentially stale project build.
for os in [linux darwin windows] {
    for arch in [amd64 arm64] {
        print -e $"  pre-compiling deps for ($os)/($arch)"
        with-env { GOOS: $os, GOARCH: $arch } { xt-precache-deps }
    }
}

# Pre-compile with the race detector for the host platform, used by gotest.
print -e "  pre-compiling deps for host (race)"
xt-precache-deps --race

# Warm the cache for the xcaddy build. Route xcaddy's stdout (its post-build
# `caddy version` check) to stderr so only the hash lands on stdout.
print -e "  pre-compiling caddy build (xcaddy)"
xt-build-caddy | print -e

# Build the deps stage and export its BuildKit layer cache to a local directory.
# Send docker's stdout (the image digest from `-q`) to stderr so it doesn't
# contaminate the hash on stdout.
print -e "  exporting docker deps build cache"
xt-build-docker --target deps --cache-to $"type=local,dest=($env.DIST_DIR)/buildx-cache,mode=max" | print -e

# Emit the hash to stdout.
print $sum
