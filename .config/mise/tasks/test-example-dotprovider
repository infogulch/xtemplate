#!/usr/bin/env nu
#MISE description="Build, serve, and integration-test the dotprovider example"
#MISE depends=["build-example-dotprovider"]
use ../lib.nu *

let work = (new-example-dir dotprovider)
let bin = ($env.DIST_DIR | path join example-dotprovider)
let server = (job spawn {
    cd $work
    ^$bin --loglevel -4 --config-file config.json --listen :0 out+err> server.log
})
let port = (wait-listen-port ($work | path join server.log))
let outcome = (try { run-example $port $work; "ok" } catch { |e| $e.msg })
job kill $server
if $outcome != "ok" {
    print -e $"test-example-dotprovider failed: ($outcome)"
    exit 1
}
