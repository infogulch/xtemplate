#!/usr/bin/env nu
#MISE description="Build, serve, and integration-test the embedded example"
#MISE depends=["build-example-embedded"]
use ../lib.nu *

let work = (new-example-dir embedded)
let bin = ($env.DIST_DIR | path join example-embedded)
let server = (job spawn {
    cd $work
    ^$bin --loglevel -4 --listen :0 out+err> server.log
})
let port = (wait-listen-port ($work | path join server.log))
let outcome = (try { run-example $port $work; "ok" } catch { |e| $e.msg })
job kill $server
if $outcome != "ok" {
    print -e $"test-example-embedded failed: ($outcome)"
    exit 1
}
