#!/usr/bin/env nu
#MISE description="Save Go build cache and Docker BuildKit layer cache to ~/.cache/xtemplate"
use ../lib.nu *
cd $env.ROOT

let home = $nu.home-dir
let cache = ($home | path join .cache xtemplate)

# Go marks module-cache files and their directories read-only, so a plain
# `rm -rf` of a previous save fails with "Permission denied". Restore write
# permission first so the directory can actually be removed.
if ($cache | path exists) {
    ^chmod -R u+w $cache
    rm -rf $cache
}
mkdir ($cache | path join go pkg)
^cp -r ($home | path join .cache go-build) ($cache | path join go-build)
^cp -r ($home | path join .local go pkg mod) ($cache | path join go pkg mod)
^cp -r ($env.ROOT | path join dist buildx-cache) ($cache | path join buildx-cache)
