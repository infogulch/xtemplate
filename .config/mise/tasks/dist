#!/usr/bin/env bash
#MISE description="Cross-compile release archives for all platforms"
set -euo pipefail
# shellcheck source=/dev/null
source "$MISE_PROJECT_ROOT/.config/mise/lib.sh"
cd "$ROOT"

ver="$(xt_version)"
# -w omits the DWARF symbol table. On darwin this avoids a slow Mach-O
# post-edit step that embeds DWARF into the binary (Go issue #12259).
# Release binaries don't need debug info, so strip it on all platforms.
ldflags="-w $(xt_ldflags)"

# Build with each platform's default buildmode (exe on linux/windows, pie on
# darwin). Forcing -buildmode=exe overrides darwin's pie default which
# invalidates prebuild caches.

echo "Building xtemplate ${ver} for all platforms..."

for os in linux darwin windows; do
	for arch in amd64 arm64; do
		name="xtemplate-${arch}-${os}"
		dir="$DIST_DIR/$name"
		exe="xtemplate"
		[ "$os" = "windows" ] && exe="xtemplate.exe"

		printf '  %-28s building...' "$name"
		start=$SECONDS
		rm -rf "$dir"
		mkdir -p "$dir"
		GOOS="$os" GOARCH="$arch" go build -ldflags "$ldflags" -o "$dir/$exe" ./cmd
		cp README.md LICENSE "$dir"
		(cd "$DIST_DIR" && zip -jqr6 "${name}_${ver}.zip" "$name")
		printf ' done (%ss)\n' "$((SECONDS - start))"
	done
done

echo "Archives written to $DIST_DIR/"
