#!/usr/bin/env bash
#MISE description="Build and tag the production Docker image"
set -euo pipefail
# shellcheck source=/dev/null
source "$MISE_PROJECT_ROOT/.config/mise/lib.sh"
cd "$ROOT"

ver="$(xt_version)"

tags=(-t "infogulch/xtemplate:${ver}")
if [ "$ver" = "$(xt_latest_tag)" ]; then
	tags+=(-t "infogulch/xtemplate:latest")
fi

docker build "${tags[@]}" --build-arg "LDFLAGS=$(xt_ldflags)" .
