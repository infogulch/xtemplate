#!/usr/bin/env nu
#MISE description="Build and tag the production Docker image"
use ../lib.nu *

# With no args, build and tag the production image. --target/--cache-to build a
# different stage, and positional tags replace the default version tags, so
# callers can build a stage without mislabeling it as a release.
def main [--target: string = "", --cache-to: string = "", ...tags: string] {
    xt-build-docker --target $target --cache-to $cache_to --tags $tags
}
