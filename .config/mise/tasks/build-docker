#!/usr/bin/env bash
#MISE description="Build and tag the production Docker image"
set -euo pipefail
# shellcheck source=/dev/null
source "$MISE_PROJECT_ROOT/.config/mise/lib.sh"
cd "$ROOT"

# With no args, build and tag the production image. Any args (e.g. from
# test-docker: `--target test -t xtemplate-test`) are forwarded to docker build
# and replace the default version tags, so callers can build a different stage
# without mislabeling it as a release.
if [ "$#" -eq 0 ]; then
	while IFS= read -r tag; do set -- "$@" -t "$tag"; done < <(xt_image_tags)
fi

docker build --build-arg "LDFLAGS=$(xt_ldflags)" "$@" .
