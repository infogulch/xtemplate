#!/usr/bin/env nu
#MISE description="Aggressively clean all build outputs"
use ../lib.nu *
cd $env.ROOT

^go clean -cache -modcache
rm -rf ($env.ROOT | path join dist)
mkdir ($env.ROOT | path join dist)

# Remove any xtemplate images, then prune the builder cache. Ignore failures
# (e.g. no matching images) so cleanup never aborts.
let images = (^docker images --format "{{.Repository}}:{{.Tag}}" | lines | where { |l| $l =~ "xtemplate" })
if not ($images | is-empty) {
    do { ^docker rmi ...$images } | complete | ignore
}
^docker builder prune -af
