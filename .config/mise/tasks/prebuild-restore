#!/usr/bin/env nu
#MISE description="Restore Go build cache and Docker BuildKit layer cache from ~/.cache/xtemplate"
use ../lib.nu *
cd $env.ROOT

let home = $nu.home-dir
let go_build = ($home | path join .cache go-build)
let mod = ($home | path join .local go pkg mod)

# Remove the destinations first so `cp -r src dest` recreates them rather than
# copying *into* an existing directory. `go clean -cache` empties GOCACHE but
# leaves the ~/.cache/go-build directory in place, so without this the cache
# would land at ~/.cache/go-build/go-build/ where Go never looks for it.
# The module cache is marked read-only by Go, so restore write permission
# before removing it (a plain `rm -rf` would fail with "Permission denied").
rm -rf $go_build
if ($mod | path exists) {
    ^chmod -R u+w $mod
    rm -rf $mod
}
mkdir ($home | path join .local go pkg)
^cp -r ($home | path join .cache xtemplate go-build) $go_build
^cp -r ($home | path join .cache xtemplate go pkg mod) $mod

# Restore the Docker BuildKit layer cache; build-docker/test-docker read it via
# --cache-from. No `docker load` needed: BuildKit imports the cache directly.
rm -rf ($env.ROOT | path join dist buildx-cache)
^cp -r ($home | path join .cache xtemplate buildx-cache) ($env.ROOT | path join dist buildx-cache)
