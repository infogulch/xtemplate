{
  "providers": [
    {
      "type": "fs",
      "name": "Posts",
      "path": "posts"
    },
    {
      "type": "sql",
      "name": "DB",
      "driver": "sqlite3",
      "connstr": ":memory:",
      "max_open_conns": 1
    }
  ],
  "source": {
    "type": "watchfs",
    "path": "templates",
    "watch_dirs": [
      "posts"
    ]
  }
}
